# syntax=docker/dockerfile:1.7
# =============================================================================
# Dockerfile multi-stage para microservicos NestJS
# Parametros: NODE_VERSION, SERVICE_NAME (ex: course-service)
#
# Usa `pnpm deploy` para criar um bundle isolado com node_modules hoisted.
# Necessário porque o monorepo usa pnpm com `shamefully-hoist=false`,
# então copiar apenas /repo/node_modules deixaria fora dependências de cada
# app que vivem em /repo/apps/<svc>/node_modules como symlinks para
# /repo/node_modules/.pnpm/...
# =============================================================================

ARG NODE_VERSION=20

# ---------- 1) Base: pnpm + workspace -----------------------------------------
FROM node:${NODE_VERSION}-alpine AS base
ENV PNPM_HOME=/pnpm \
    PATH=/pnpm:$PATH \
    CI=true
RUN corepack enable && corepack prepare pnpm@9.12.0 --activate
WORKDIR /repo

# ---------- 2) Deps (cacheavel) -----------------------------------------------
FROM base AS deps
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* .npmrc ./
COPY turbo.json tsconfig.base.json ./
COPY packages ./packages
COPY apps ./apps
RUN --mount=type=cache,id=pnpm,target=/pnpm/store \
    pnpm install --frozen-lockfile=false

# ---------- 3) Build compartilhado (cache cross-service) ----------------------
# Compila workspace package uma única vez e reaproveita o layer entre serviços.
FROM deps AS shared-build
RUN set -eux; \
    pnpm --filter "@coast-academy/shared-types" run build; \
    pnpm --filter "@coast-academy/observability" run build; \
    test -f packages/observability/dist/index.js; \
    test -f packages/observability/dist/index.d.ts

# ---------- 4) Build do servico alvo + deploy isolado -------------------------
FROM shared-build AS build
ARG SERVICE_NAME
ENV SERVICE_NAME=${SERVICE_NAME}
# Reutiliza dist/ do shared-build (nao recompilar observability aqui).
RUN set -eux; \
    test -f packages/observability/dist/index.js; \
    cd "apps/${SERVICE_NAME}"; \
    rm -f tsconfig.tsbuildinfo; \
    node -e "require.resolve('@coast-academy/observability')"; \
    pnpm run build; \
    test -f dist/main.js
# pnpm deploy: cria um bundle standalone em /deploy com node_modules hoisted.
RUN pnpm --filter "./apps/${SERVICE_NAME}" --prod deploy /deploy

# ---------- 5) Runtime mínimo --------------------------------------------------
FROM node:${NODE_VERSION}-alpine AS runtime
ARG SERVICE_NAME
ENV NODE_ENV=production \
    SERVICE_NAME=${SERVICE_NAME} \
    PORT=3000 \
    TINI_SUBREAPER=1
RUN apk add --no-cache wget tini && \
    addgroup -g 1001 coastacademy && \
    adduser -D -u 1001 -G coastacademy coastacademy
WORKDIR /app
COPY --from=build --chown=coastacademy:coastacademy /deploy ./
USER coastacademy
EXPOSE 3000
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD wget -qO- http://127.0.0.1:3000/health || exit 1
ENTRYPOINT ["/sbin/tini", "-s", "--"]
CMD ["node", "dist/main.js"]
