{
  "name": "@coast-academy/observability",
  "version": "0.1.0",
  "private": true,
  "description": "Métricas Prometheus, logs Pino e middleware HTTP para microserviços NestJS (SPEC-001)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').accessSync('dist/index.js')\"",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .tsbuildinfo",
    "test": "echo 'no tests yet'"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^1.28.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/instrumentation-express": "^0.47.0",
    "@opentelemetry/instrumentation-http": "^0.57.0",
    "@opentelemetry/instrumentation-nestjs-core": "^0.44.0",
    "@opentelemetry/resources": "^1.28.0",
    "@opentelemetry/sdk-node": "^0.57.2",
    "nestjs-pino": "^4.1.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@coast-academy/eslint-config": "workspace:*",
    "@types/express": "^4.17.21",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.4"
  }
}
