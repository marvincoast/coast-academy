{
  "name": "@coast-academy/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Componentes e design tokens Coast Academy reutilizaveis no frontend",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./tailwind-preset": {
      "import": "./tailwind-preset.cjs",
      "require": "./tailwind-preset.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "tailwind-preset.cjs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .tsbuildinfo",
    "test": "vitest run"
  },
  "devDependencies": {
    "@coast-academy/eslint-config": "workspace:*",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.2"
  }
}
