{
  "extends": ["../../tsconfig.base.json", "../../tsconfig.paths.json"],
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "types": ["vite/client", "vitest/globals"],
    "paths": {
      "@/*": ["./src/*"],
      "@coast-academy/ui": ["../../packages/ui/src/index.ts"],
      "@coast-academy/shared-types": ["../../packages/shared-types/src/index.ts"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"],
  "exclude": ["dist", "node_modules", "e2e"]
}
