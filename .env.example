# =============================================================================
# Coast Academy - Variaveis de ambiente
# Copie para .env.local e preencha os valores. NUNCA commitar segredos reais.
# =============================================================================

# -------- Ambiente --------
NODE_ENV=development
LOG_LEVEL=info

# -------- Frontend (apps/web) --------
# Use /api (relativo) para http://coastacademy, http://localhost e :3000 com proxy nginx.
VITE_API_BASE_URL=/api
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Projeto Sentry (browser). Vazio = no-op no build.
VITE_SENTRY_DSN=
# Aba de links locais na página de login (dev). Use false em builds de apresentação “limpa”.
VITE_DEV_LOCAL_LINKS=true

# -------- Supabase (servidor / microserviços no Docker) --------
# Em dev com Supabase CLI (rede supabase_network_coast-academy):
# SUPABASE_URL=http://kong:8000
# (browser usa VITE_SUPABASE_URL com 127.0.0.1:54321)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -------- Postgres direto (dev local via supabase start) --------
POSTGRES_HOST=localhost
POSTGRES_PORT=54322
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# -------- LLM / RAG --------
LLM_API_BASE=http://ollama:11434/v1
LLM_MODEL=qwen2.5:1.5b
LLM_API_KEY=
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_MS=60000
# Local (Ollama): nomic-embed-text = 768 dims — migration 0012
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
# Cloud (OpenAI): text-embedding-3-small = 1536 — exige migration 0007 sem 0012
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536

# -------- E-mail (Resend) --------
RESEND_API_KEY=
EMAIL_FROM="Coast Academy <no-reply@coast-academy.local>"

# -------- Anti-cheat / Avaliacoes --------
ASSESSMENT_MIN_SECONDS_PER_QUESTION=5
ASSESSMENT_MAX_ATTEMPTS=3
PASSING_SCORE=0.75

# -------- Certificado --------
CERTIFICATE_PUBLIC_VERIFY_BASE_URL=http://localhost/verify
CERTIFICATE_ISSUER_NAME=Empire Trading
# Storage: appwrite (bucket S3cert) | supabase
CERTIFICATE_DEV_PREVIEW=true
CERTIFICATE_STORAGE_PROVIDER=supabase
APPWRITE_ENDPOINT=http://localhost/v1
APPWRITE_PROJECT_ID=your-project-id
APPWRITE_API_KEY=your-api-key-with-files-write
APPWRITE_CERT_BUCKET_ID=S3cert
# Fallback Supabase Storage (se CERTIFICATE_STORAGE_PROVIDER=supabase)
SUPABASE_CERT_BUCKET_ID=certificates
# Use S3cert se você criou esse bucket no Studio (migration 0016)
SUPABASE_PUBLIC_URL=http://127.0.0.1:54321

# -------- Observabilidade (SPEC-001 / OBS-T07+) --------
# Hostname do serviço compose na rede coast-academy-net (profile obs).
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=none
# Sobrescrito por serviço no docker-compose (certificate-service, etc.)
OTEL_SERVICE_NAME=coast-academy
# Traefik (OBS-T09): tracing em infra/traefik/traefik.yml → alloy:4318; serviceName traefik-gateway
# OTEL_PROPAGATORS=tracecontext,baggage (docker-compose.yml)
# certificate-service (OBS-T10). Vazio = no-op.
SENTRY_DSN=
# Rota GET /api/certificates/debug/sentry-test. false em ambientes prod-like.
SENTRY_TEST=true
# Observabilidade (profile obs) — ./infra/scripts/obs-up.sh
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# -------- Gateway / Rate limit --------
RATE_LIMIT_RPM=120
CORS_ALLOWED_ORIGINS=http://coastacademy,http://localhost,http://localhost:5173
