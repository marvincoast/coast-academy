# =============================================================================
# Coast Academy — .dockerignore
# Drasticamente reduz o tempo de "load build context" excluindo dependências,
# build artifacts, VCS metadata, IDE files e binários grandes.
# =============================================================================

# Node / pnpm artifacts (HUGE — must exclude)
**/node_modules
**/.pnpm-store
**/.pnpm
**/pnpm-debug.log

# Build artifacts
**/dist
**/build
**/.next
**/.turbo
**/coverage
**/.tsbuildinfo

# Git / VCS
.git
.gitignore
.gitattributes
.github

# Environment files (não copiar segredos)
.env
.env.local
.env.*.local

# IDE / OS
.vscode
.idea
.DS_Store
Thumbs.db

# Logs / temp
*.log
*.tmp
npm-debug.log*
yarn-debug.log*

# Docker / infra (não precisamos dentro da imagem)
Dockerfile*
docker-compose*.yml
.dockerignore

# Tests / docs (não vão pra imagem de produção)
**/playwright-report
**/test-results
**/__tests__/__snapshots__
docs
.husky

# Supabase local data (nunca no container)
supabase/.branches
supabase/.temp

# Cypress / Playwright
**/cypress
**/playwright

# Backups
infra/backups/*.sql.gz
infra/backups/*.sql
